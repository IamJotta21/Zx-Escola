# App Settings
PORT=3000
NODE_ENV=development

# Database Settings (Docker defaults)
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/zx_escola_db?schema=public"

# JWT Secrets (Make sure to change these in production!)
JWT_SECRET="super-secret-jwt-token-key-change-in-prod-at-least-32-chars-long"
JWT_REFRESH_SECRET="super-secret-refresh-token-key-change-in-prod-at-least-32-chars-long"

# Supabase Storage Integration
SUPABASE_URL="https://your-supabase-project-id.supabase.co"
SUPABASE_KEY="your-supabase-service-role-or-anon-key"
SUPABASE_BUCKET="school-storage"
