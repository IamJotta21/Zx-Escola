# =============================================================================
# Zx-Escola — Environment Variables Template
# Copy this file to .env and fill in your values before running.
# NEVER commit the .env file to version control.
# =============================================================================

# ─── Ports ───────────────────────────────────────────────────────────────────
BACKEND_PORT=3000
FRONTEND_PORT=5173

# ─── Database ─────────────────────────────────────────────────────────────────
# Development: SQLite (default — no setup required)
DATABASE_URL="file:./dev.db"
# Production PostgreSQL example:
# DATABASE_URL="postgresql://zx_user:SenhaSegura@db:5432/zx_escola_prod?schema=public"

# ─── JWT (MANDATORY — change these in production!) ───────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_ALPHANUMERIC_STRING
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_MIN_32_CHARS_STRING

# ─── Supabase (optional — for cloud file storage) ─────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=school-storage

# ─── OpenAI (optional — for AI Assistant features) ───────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# Leave blank to use the built-in demo/simulation mode (no cost)
OPENAI_API_KEY=

# ─── CORS (production) ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * only for development.
# Production example: https://app.minhaescola.com,https://admin.minhaescola.com
ALLOWED_ORIGINS=*

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api
